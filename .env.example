PORT=3000
NODE_ENV=development
MISTRAL_API_KEY=replace-me
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TIMEOUT_MS=15000
CORS_ORIGIN=*
TRUST_PROXY=false
CHAT_API_KEYS=replace-with-a-long-random-secret
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW_MS=60000
MAX_CONCURRENT_CHATS=8
MAX_MESSAGE_LENGTH=2000
MAX_HISTORY_ITEMS=12
MAX_PROMPT_CHARACTERS=12000
